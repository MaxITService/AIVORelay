{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AivoRelay",
  "version": "0.9.8",
  "identifier": "fi.maxits.aivorelay",
  "build": {
    "beforeDevCommand": "tsc --noEmit && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "AivoRelay (Store Edition)",
        "width": 680,
        "height": 570,
        "minWidth": 680,
        "minHeight": 570,
        "resizable": true,
        "maximizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'none'"],
        "base-uri": ["'none'"],
        "connect-src": ["'self'", "ipc:", "http://ipc.localhost"],
        "font-src": ["'self'"],
        "form-action": ["'none'"],
        "frame-ancestors": ["'none'"],
        "frame-src": ["'none'"],
        "img-src": ["'self'", "data:", "asset:", "http://asset.localhost"],
        "media-src": ["'self'", "asset:", "http://asset.localhost"],
        "object-src": ["'none'"],
        "script-src": ["'self'"],
        "style-src": ["'self'"],
        "style-src-attr": ["'unsafe-inline'"],
        "style-src-elem": ["'self'"],
        "worker-src": ["'none'"]
      },
      "devCsp": {
        "default-src": ["'none'"],
        "base-uri": ["'none'"],
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost",
          "ws://localhost:1420",
          "ws://127.0.0.1:1420",
          "ws://localhost:1421",
          "ws://127.0.0.1:1421"
        ],
        "font-src": ["'self'"],
        "form-action": ["'none'"],
        "frame-ancestors": ["'none'"],
        "frame-src": ["'none'"],
        "img-src": ["'self'", "data:", "asset:", "http://asset.localhost"],
        "media-src": ["'self'", "asset:", "http://asset.localhost"],
        "object-src": ["'none'"],
        "script-src": ["'self'"],
        "style-src": ["'self'"],
        "style-src-attr": ["'unsafe-inline'"],
        "style-src-elem": ["'self'"],
        "worker-src": ["'none'"]
      },
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/recordings/**",
            "$APPCACHE/transcribe-file-preview/**"
          ],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "publisher": "MaxITService",
    "copyright": "Copyright © 2026 Maxim Fomin",
    "shortDescription": "AivoRelay - AI Voice Relay",
    "createUpdaterArtifacts": false,
    "targets": "msi",
    "resources": ["resources/**/*", "vulkan-1.dll"],
    "license": "MIT",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "files": {},
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.13",
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist"
    },
    "linux": {
      "rpm": {
        "compression": {
          "type": "none"
        }
      },
      "appimage": {
        "bundleMediaFramework": true,
        "files": {}
      }
    },
    "windows": {
      "wix": {
        "template": "./windows/wix/main.wxs"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4NjVDMjVCMEY3REY4OTYKUldTVytIMFBXOEpseUk1NCtIM0ROTklHdS9MVUNyNVZTM3c5ZFoxdXRRdWE5cjVUaWRpbUhTUHoK",
      "endpoints": []
    }
  }
}
